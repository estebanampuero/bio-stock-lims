FROM node:22-alpine AS builder
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

# ─────────────────────────────────────────────────────────────────────────────
# El stage de runtime solo copia los archivos compilados al volumen compartido
# Nginx los sirve directamente desde ese volumen
FROM alpine:3.20
WORKDIR /app/dist
COPY --from=builder /app/dist ./
