# ═══════════════════════════════════════════════════════════════════════════════
# BIO-STOCK LIMS — Variables de Entorno
# INSTRUCCIONES: Copiar este archivo como .env y completar los valores
# NUNCA commitear el .env real al repositorio
# ═══════════════════════════════════════════════════════════════════════════════

# ── Puerto del servidor en la red local ───────────────────────────────────────
# Los clientes acceden vía http://IP_SERVIDOR:HOST_PORT
HOST_PORT=80

# ── Seguridad JWT ─────────────────────────────────────────────────────────────
# CRÍTICO: Cambiar por strings aleatorios largos antes del primer despliegue
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_STRING_ALEATORIO_LARGO_MINIMO_64_CHARS
JWT_REFRESH_SECRET=CAMBIAR_POR_OTRO_STRING_ALEATORIO_DIFERENTE_AL_ANTERIOR
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Base de datos ─────────────────────────────────────────────────────────────
# Ruta interna del contenedor (el volumen ./data se monta aquí)
DB_PATH=/app/data/inventario_biorad.db

# ── Logs ──────────────────────────────────────────────────────────────────────
# Niveles: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── CORS ──────────────────────────────────────────────────────────────────────
# En red local pura, se puede dejar en * o especificar la IP del servidor
# Ejemplo: http://192.168.1.100
ALLOWED_ORIGIN=*

# ── Configuración de backups automáticos ──────────────────────────────────────
# Cuántos días conservar backups automáticos antes de eliminar los más antiguos
BACKUP_RETENTION_DAYS=30
